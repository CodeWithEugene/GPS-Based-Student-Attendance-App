# Copy this file to `.env` and paste in the values from your Supabase project.
# Settings → API  (https://supabase.com/dashboard/project/_/settings/api)
#
# Both values are safe to ship in a mobile app (public).
# Row-Level-Security policies in schema.sql do the real gatekeeping.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
